subscription_id      = "00000000-0000-0000-0000-000000000000"
resource_group_name  = "terravault-prod-rg"
location             = "eastus"
storage_account_name = "terravaultprod001"

# Prod is geo-zone-redundant and versioned.
account_replication_type = "GZRS"
versioning_enabled       = true

# Customer-managed key is MANDATORY in prod (enforced by variable validation).
customer_managed_key = {
  key_vault_resource_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/terravault-prod-rg/providers/Microsoft.KeyVault/vaults/terravault-prod-kv"
  key_name              = "storage-cmk"
  # key_version optional -- omit to auto-rotate to the latest key version.
  user_assigned_identity = {
    resource_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/terravault-prod-rg/providers/Microsoft.ManagedIdentity/userAssignedIdentities/terravault-storage-mi"
  }
}

lifecycle_rules = {}

tags = {
  cost_center = "data-platform"
  compliance  = "required"
}
